{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "models/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/register",
      "dest": "server.js"
    },
    {
      "src": "/api/login",
      "dest": "server.js"
    },
    {
      "src": "/api/users",
      "dest": "server.js"
    },
    {
      "src": "/api/messages/poll",
      "dest": "server.js"
    },
    {
      "src": "/api/messages",
      "dest": "server.js"
    },
    {
      "src": "/chat",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "server.js"
    }
  ]
}
